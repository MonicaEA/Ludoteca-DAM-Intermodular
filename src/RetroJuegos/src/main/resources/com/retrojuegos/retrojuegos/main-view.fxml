<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>


<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.retrojuegos.retrojuegos.ControllerView.MainViewController">
   <children>
      <BorderPane maxWidth="1.7976931348623157E308" prefHeight="600.0" prefWidth="800.0">
         <center>
            <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="336.0" prefWidth="800.0" spacing="40.0" BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="btnComprar" contentDisplay="TOP" minHeight="100.0" minWidth="100.0" mnemonicParsing="false" text="COMPRAR">
                     <graphic>
                        <ImageView fitHeight="54.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true" style="-fx-blend-mode: 1;">
                           <image>
                              <Image url="@images/comprar.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
                  <Button fx:id="btnVender" contentDisplay="TOP" minHeight="100.0" minWidth="100.0" mnemonicParsing="false" text="VENDER">
                     <graphic>
                        <ImageView fitHeight="69.0" fitWidth="62.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/vender.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
                  <Button fx:id="btnStock" contentDisplay="TOP" minHeight="100.0" minWidth="100.0" mnemonicParsing="false" text="VER STOCK">
                     <graphic>
                        <ImageView fitHeight="63.0" fitWidth="62.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/buscar.png" />
                           </image>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </ImageView>
                     </graphic>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
                  <Button fx:id="btnFinanzas" contentDisplay="TOP" minHeight="100.0" minWidth="100.0" mnemonicParsing="false" text="FINANZAS">
                     <graphic>
                        <ImageView fitHeight="62.0" fitWidth="88.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/finanzas.png" />
                           </image>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </ImageView>
                     </graphic>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </HBox>
         </center>
         <bottom>
            <ButtonBar buttonMinWidth="90.0" prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <buttons>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="853.0">
                     <children>
                      <Button fx:id="btnDeslogarse" alignment="CENTER" minHeight="100.0" minWidth="100.0" mnemonicParsing="false" text="DESLOGARSE" />
                     </children>
                     <padding>
                        <Insets bottom="15.0" />
                     </padding>
                  </HBox>
              </buttons>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </ButtonBar>
         </bottom>
         <top>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="MENÚ PRINCIPAL">
                     <font>
                        <Font size="36.0" />
                     </font>
                  </Text>
               </children>
               <BorderPane.margin>
                  <Insets bottom="-60.0" />
               </BorderPane.margin>
            </VBox>
         </top>
      </BorderPane>
   </children>
</StackPane>
